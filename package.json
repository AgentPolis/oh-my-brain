{
  "name": "squeeze-claw",
  "version": "0.1.0",
  "description": "Cut context token cost by 30-60% — semantic-aware context compression for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicholasgasior/squeeze-claw.git"
  },
  "homepage": "https://github.com/nicholasgasior/squeeze-claw#readme",
  "bugs": {
    "url": "https://github.com/nicholasgasior/squeeze-claw/issues"
  },
  "bin": {
    "squeeze-compress": "./dist/cli/compress.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && tsup cli/compress.ts --format esm --no-dts --out-dir dist/cli",
    "build:cli": "tsup cli/compress.ts --format esm --no-dts --out-dir dist/cli",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "context-engine",
    "context-compression",
    "token-optimization",
    "llm",
    "agent",
    "semantic-triage"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
